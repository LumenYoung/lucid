# Graphiti runtime settings
CONFIG_PATH=/app/mcp/config/config.yaml
FALKORDB_URI=redis://lucid-falkordb:6379
FALKORDB_PASSWORD=change-me
FALKORDB_DATABASE=default_db
GRAPHITI_GROUP_ID=main
USER_ID=lucid_mcp
SEMAPHORE_LIMIT=4

# OpenAI defaults for v1
OPENAI_API_KEY=
OPENAI_API_URL=https://api.openai.com/v1
OPENAI_ORGANIZATION_ID=
GRAPHITI_LLM_PROVIDER=openai
GRAPHITI_LLM_MODEL=gpt-4o-mini
GRAPHITI_EMBEDDER_PROVIDER=openai
GRAPHITI_EMBEDDER_MODEL=text-embedding-3-small

# The public edge token is not read from this env file.
# Put LUCID_PUBLIC_HOSTNAME and LUCID_API_TOKEN in the compose project .env
# because compose labels interpolate from the project env, not from service
# env files.
